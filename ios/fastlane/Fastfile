# Fastfile for EquiCalendar (iOS) — local TestFlight pipeline.
#
# Project is generated by xcodegen from project.yml (the .xcodeproj is git-ignored),
# so the lane regenerates before building. Versioning uses agvtool (apple-generic),
# never sed (per CLAUDE.md). The App Store Connect API key is team-level and read
# from env vars set in ~/.zshrc (ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_PATH) — see
# ~/.claude/ios-cicd-playbook.md.

default_platform(:ios)

APP_IDENTIFIER = "dev.dreamfold.equicalendar"
XCODEPROJ = "EquiCalendar.xcodeproj"
SCHEME = "EquiCalendar"
# SemVer marketing version — bump BY HAND per release, decoupled from the build
# number: patch=fix (1.0 -> 1.0.1), minor=feature (1.0 -> 1.1), major=rewrite (-> 2.0).
# The build number below is the monotonic TestFlight counter (agvtool), not part of this.
MARKETING_VERSION = "1.0"

# App Store Connect API key from team-level env vars (no fallbacks — required).
def api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_PATH"),
  )
end

platform :ios do
  desc "Register the app in App Store Connect (one-time — run before the first beta)"
  lane :register_app do
    api_key # sets the shared App Store Connect API token that produce reads
    produce(
      app_identifier: APP_IDENTIFIER,
      app_name: "EquiCalendar",
      language: "English (U.K.)",
      sku: "equicalendar",
      team_id: "N6BK2WX94Z",
    )
  end

  desc "Build and upload a new build to TestFlight"
  lane :beta do
    key = api_key

    # project.yml is the source of truth — regenerate the .xcodeproj first.
    sh("cd .. && xcodegen generate")

    # Unique, monotonic build number derived from TestFlight.
    build = latest_testflight_build_number(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0,
    ) + 1

    # Version via agvtool (apple-generic): monotonic build number, plus the
    # hand-managed SemVer marketing version (a build bump is NOT a version bump).
    sh("cd .. && xcrun agvtool new-version -all #{build}")
    sh("cd .. && xcrun agvtool new-marketing-version #{MARKETING_VERSION}")

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      clean: true,
      # Let xcodebuild create the distribution profile via the ASC API key
      # (set above) on the first build — no interactive portal login needed.
      xcargs: "-allowProvisioningUpdates",
    )

    upload_to_testflight(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Submit the existing TestFlight build for App Store review (deliver). " \
       "Reuses the build already on TestFlight (no new binary), uploads the " \
       "fastlane/metadata + fastlane/screenshots, and submits for review. " \
       "Run AFTER the ASC-UI-only gates are done (App Privacy, Age Rating, " \
       "Pricing & Availability) and the metadata/screenshots are reviewed."
  lane :promote do
    key = api_key

    # Attach the LATEST processed TestFlight build to the App Store version — never
    # submit whatever stale build happens to still be selected on the version.
    build = latest_testflight_build_number(api_key: key, app_identifier: APP_IDENTIFIER).to_s
    UI.message("Promoting build #{build} to App Store review")

    upload_to_app_store(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      # Reuse the build already processed on TestFlight — don't build/upload one.
      skip_binary_upload: true,
      build_number: build,
      # Submit metadata + screenshots from the fastlane/ tree.
      skip_metadata: false,
      skip_screenshots: false,
      # Don't prompt for the HTML preview before uploading.
      force: true,
      submit_for_review: true,
      # Auto-release as soon as Apple approves — no manual publish step.
      automatic_release: true,
      # No in-app purchases to precheck.
      precheck_include_in_app_purchases: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
        content_rights_contains_third_party_content: false,
      },
    )
  end

  desc "Read-only: check App Store submission readiness WITHOUT submitting."
  lane :verify do
    require "spaceship"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      filepath: ENV.fetch("ASC_KEY_PATH"),
    )
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    aid = app.id
    UI.header("Submission readiness for #{app.name} (#{aid})")

    show = lambda do |label, ok, detail = nil|
      mark = ok.nil? ? "⚠️ " : (ok ? "✅" : "❌")
      UI.message("#{mark} #{label}#{detail ? " — #{detail}" : ''}")
    end
    ver = nil
    begin
      ver = app.get_edit_app_store_version(includes: "build")
      show.call("Edit version present", !ver.nil?, ver && "v#{ver.version_string} (#{ver.app_store_state})")
      show.call("Build attached", !(ver && ver.build).nil?, ver&.build && "build #{ver.build.version}")
    rescue => e
      show.call("Version / build", nil, "#{e.class}: #{e.message[0, 80]}")
    end

    begin
      info = app.fetch_edit_app_info || app.fetch_latest_app_info
      ard = Spaceship::ConnectAPI.get_age_rating_declaration(app_info_id: info.id)
      vals = ard.instance_variables
        .reject { |v| %i[@id @type @client].include?(v) }
        .map { |v| ard.instance_variable_get(v) }
      answered = vals.count { |v| !v.nil? }
      show.call("Age Rating set", answered > 0, "#{answered} questionnaire attribute(s) answered")
    rescue => e
      show.call("Age Rating", nil, "#{e.class}: #{e.message[0, 90]}")
    end

    # Pricing & App Privacy aren't exposed by fastlane/spaceship even at 2.236.1
    # (Apple's newest ASC models): confirm those two in the ASC web UI.
    show.call("Pricing", nil, "not exposed by fastlane — confirm in ASC")
    show.call("App Privacy", nil, "not exposed by fastlane — confirm in ASC")

    UI.important("Read-only check — nothing was submitted.")
  end

  desc "Capture App Store screenshots (6.9\" iPhone 17 Pro Max, en-GB) into " \
       "fastlane/screenshots via the EquiCalendarUITests UI test."
  lane :screenshots do
    # project.yml is the source of truth — regenerate so the UI-test target exists.
    sh("cd .. && xcodegen generate")
    capture_screenshots(
      project: XCODEPROJ,
      test_without_building: false,
    )
  end
end
